{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "isolatedModules": true
  },
  "include": ["./**/*", ".auth.config.ts"],
  "exclude": ["./_generated"]
}
