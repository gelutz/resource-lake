{
  "name": "resources/feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/resources/feature/src",
  "projectType": "library",
  "tags": ["type:feature", "scope:resources"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/resources/feature",
        "main": "libs/resources/feature/src/index.ts",
        "tsConfig": "libs/resources/feature/tsconfig.lib.json",
        "assets": ["libs/resources/feature/*.md"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "coverage/libs/resources/feature"
      }
    }
  }
}
